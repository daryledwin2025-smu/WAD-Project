}

exports.submitRegister = async (req, res) => {
  let username = req.body.username;
  let pass = req.body.pass;
  pass = await bcrypt.hash(pass, 10);
  let email = req.body.email;
  let phone = req.body.phone;
  let gender = req.body.gender;
  let account = req.body.account;
  if (account !== "Shelter") {
    shelterName = null;
    shelterEmail = null;
    shelterAddress = null;
    shelterNumber = null;
  } else {
    shelterName = req.body.shelterName;
    shelterEmail = req.body.shelterEmail;
    shelterAddress = req.body.shelterAddress;
    shelterNumber = req.body.shelterNumber;
  }
  let newUser = { username, pass, email, phone, gender, account, shelterName, shelterEmail, shelterNumber, shelterAddress };

  // if (username && pass && account) {
  //     user = { username, pass, account };
  try {
    await User.createUser(newUser);
    console.log("User created success");
    return res.redirect("/");
  } catch (error) {
    console.log("error", { error });
    return res.redirect("/user-register");
  }
  // }
  // res.render("user-login", { user });
}


exports.deleteAccount = async (req, res) => {
  try {
    if (!req.session || !req.session.user) {
      return res.redirect('/user-login');
    }

    const user = req.session.user;

    await User.deleteUserByUsername(user.username);

    req.session.destroy((err) => {
      if (err) {
        return res.render('error', { error: err });
      }
      res.redirect('/user-login');
    });
  } catch (error) {
    console.log(error);
    res.render('error', { error });
  }
};

exports.showHome = async (req, res) => {
  try {
    if (!req.session.user) {
      return res.redirect("/user-login");
    }
    const user = req.session.user;
    const shelters = await User.getAllShelters();

    return res.render("home", { user, shelters });
  } catch (error) {
    console.log(error);
    return res.render("error", { error });
  }
};

exports.showHomeShelter = (req, res) => {
  if (!req.session.user) {
    return res.redirect("/user-login");
  } else {
    if (req.session.user.account === "Shelter") {
      return res.render("home-shelter", { user: req.session.user }); // edited 
    } else {
      return res.redirect("/home")
    }
  }
}


exports.showAllShelters = async (req, res) => {
  try {
    const shelters = await User.getAllShelters();
    res.render("all-shelters", { shelters });
  } catch (error) {
    console.log(error);
    res.render("error", { error });
  }
};