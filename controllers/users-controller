const User = require("../models/user-model");
const bcrypt = require("bcrypt");

exports.displayLogin = (req, res) => {
  return res.render("user-login", { user: undefined });
}

exports.submitLogin = async (req, res) => {
  const username = req.body.username;
  const pass = req.body.pass;
  try {
    const user = await User.getUserByUsername(username);
    // user contrains infor stored from MongoDB
    if (!user) {
      return res.redirect("/user-login")
    } else {
      const match = await bcrypt.compare(pass, user.pass);
      if (match) {
        req.session.user = user;
        console.log(user.account)
        if (user.account === "Shelter") {
          console.log("GOING TO HOME-SHELTER");
          return res.redirect("/home-shelter");
        } else {
          console.log("GOING TO HOME");
          return res.redirect("/home")
        }
      } else {
        return res.redirect("/user-login")
      }
    }
  } catch (error) {
    return res.redirect("/user-login")
  }
}
