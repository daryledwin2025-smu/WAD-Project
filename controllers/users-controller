exports.editProfile = (req, res) => {
  try {
    if (!req.session || !req.session.user) {
      return res.redirect('/user-login');  // not logged in
    }

    res.render('user-edit', { user: req.session.user });
  } catch (error) {
    console.log(error);
    res.render('error', { error });
  }
};

exports.displayRegister = (req, res) => {
