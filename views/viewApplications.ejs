<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Applications for <%= pet.name %></title>
</head>
<body>
    <header>
        <nav>
            <a href="/home-shelter">Shelter Home</a> | 
            <a href="/pets/myListings">My Pet Listings</a>
        </nav>
    </header>

    <main>
        <h1>Adoption Applications for <%= pet.name %></h1>
        
        <div style="margin-bottom: 20px;">
            <a href="/pets/myListings">← Back To My Listings</a>
        </div>

        <% if (applications.length === 0) { %>
            <p>There are no submitted applications for this pet yet.</p>
        <% } else { %>
            <table border="1" cellpadding="10" cellspacing="0" style="width: 100%; text-align: left;">
                <thead>
                    <tr style="background-color: #f2f2f2;">
                        <th>Applicant</th>
                        <th>Contact Email</th>
                        <th>Living Situation</th>
                        <th>Experience</th>
                        <th>Date Applied</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% applications.forEach(function(app) { %>
                        <% if (app.status !== 'Draft') { %>
                            <tr>
                                <td><%= app.applicant.username %></td>
                                <td><%= app.applicant.email %></td>
                                <td><%= app.livingSituation %></td>
                                <td><%= app.experienceDetails %></td>
                                <td><%= app.applicationDate.toDateString() %></td>
                                <td>
                                    <strong><%= app.status %></strong>
                                </td>
                                <td>
                                    <% if (app.status === 'Pending') { %>
                                        <form action="/applications/status/<%= app._id %>" method="POST" style="display:inline;">
                                            <button type="submit" name="newStatus" value="Approved">Approve</button>
                                            <button type="submit" name="newStatus" value="Rejected">Reject</button>
                                        </form>
                                    <% } else { %>
                                        <em>Decision Finalized</em>
                                    <% } %>
                                </td>
                            </tr>
                        <% } %>
                    <% }); %>
                </tbody>
            </table>
        <% } %>
    </main>
</body>
</html>