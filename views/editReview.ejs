<!DOCTYPE html>
<html>
<head><title>Edit Review</title></head>
<body>
    <a href="/browse?shelterId=<%= shelterId %>">← Back to shelter</a>
    <h2>Edit Review</h2>
    <form action="/browse/reviews/<%= review._id %>/edit" method="POST">
        <input type="hidden" name="shelterId" value="<%= shelterId %>">
        <label>Rating:</label>
        <select name="rating">
            <option value="5" <%= review.rating == 5 ? 'selected' : '' %>>⭐⭐⭐⭐⭐ 5</option>
            <option value="4" <%= review.rating == 4 ? 'selected' : '' %>>⭐⭐⭐⭐ 4</option>
            <option value="3" <%= review.rating == 3 ? 'selected' : '' %>>⭐⭐⭐ 3</option>
            <option value="2" <%= review.rating == 2 ? 'selected' : '' %>>⭐⭐ 2</option>
            <option value="1" <%= review.rating == 1 ? 'selected' : '' %>>⭐ 1</option>
        </select>
        <br><br>
        <label>Comment:</label><br>
        <textarea name="comment" rows="4" cols="50" required><%= review.comment %></textarea>
        <br><br>
        <button type="submit">Save Changes</button>
    </form>
</body>
</html>