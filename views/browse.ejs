<!DOCTYPE html>
<html>
<head>
    <title>Pets</title>
    <style>
        table {
            border-collapse: collapse;
            width: 80%;
            margin: 20px auto;
        }
        th, td {
            border: 1px solid black;
            padding: 10px;
            text-align: left;
        }
        th {
            background-color: #f2f2f2;
        }
    </style>
</head>
<body>

    <h2 style="text-align:center;">Pets In <%=shelterId%>(make this nicer ltr lol)</h2>
    
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Breed</th>
                <th>Age</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            <% allPets.forEach(pet => { %>
                <tr>
                    <td><%= pet.name %></td>
                    <td><%= pet.breed %></td>
                    <td><%= pet.age %></td>
                    <td><%= pet.description %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

</body>
</html>