<!DOCTYPE html>
<html>
<head>
    <title>Pets</title>
    <style>
        table {
            border-collapse: collapse;
            width: 80%;
            margin: 20px auto;
        }
        th, td {
            border: 1px solid black;
            padding: 10px;
            text-align: left;
        }
        th {
            background-color: #f2f2f2;
        }
    </style>
</head>
<body>

    <h2 style="text-align:center;">Pets In <%=shelterId%>(make this nicer ltr lol)</h2>
    
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Breed</th>
                <th>Age</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
            <% allPets.forEach(pet => { %>
                <tr>
                    <td><%= pet.name %></td>
                    <td><%= pet.breed %></td>
                    <td><%= pet.age %></td>
                    <td><%= pet.description %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

<hr>
<h3>Adoption</h3>
<a href="../myApplications>">Adoption application</a>
<h3>Reviews <%= avgRating ? '⭐ ' + avgRating + '/5' : '' %></h3>

<% if (reviews.length === 0) { %>
    <p>No reviews yet.</p>
<% } else { %>
    <% reviews.forEach(review => { %>
        <p><strong><%= review.reviewer.username %></strong> — ⭐ <%= review.rating %>/5</p>
        <p><%= review.comment %></p>
        <p><small><%= new Date(review.createdAt).toDateString() %></small></p>

        <% if (user && review.reviewer._id.toString() === user._id.toString()) { %>
            <a href="/browse/reviews/<%= review._id %>/edit">Edit</a>
            <form action="/browse/reviews/<%= review._id %>/delete" method="POST" style="display:inline;">
                <input type="hidden" name="shelterId" value="<%= shelterId %>">
                <button type="submit">Delete</button>
            </form>
        <% } %>
        <hr>
    <% }) %>
<% } %>

<a href="/browse/reviews/all?shelterId=<%= shelterId %>">See all reviews →</a>


</body>
</html>